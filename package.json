{
  "name": "@slikts/satteri",
  "version": "0.9.4",
  "description": "High-performance Markdown and MDX processing",
  "private": true,
  "license": "MIT",
  "author": "Bruits",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "browser.js",
    "index.js",
    "index.d.ts",
    "webcontainer-fallback.cjs",
    "satteri_napi*.node",
    "satteri_napi.wasi*.cjs",
    "satteri_napi.wasi*.js"
  ],
  "imports": {
    "#binding": {
      "browser": "./dist/binding.browser.js",
      "default": "./dist/binding.js"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prepare": "pnpm --dir packages/satteri build && node scripts/copy-package-artifacts.mjs",
    "lint": "oxlint && cargo clippy && knip",
    "lint:fix": "oxlint --fix && cargo clippy --fix --allow-dirty",
    "format": "oxfmt && cargo fmt",
    "codegen": "cargo run -p satteri-layout-codegen && pnpm format",
    "codegen:check": "pnpm codegen && git diff --exit-code -- ':(glob)**/generated/*' && test -z \"$(git status --porcelain -- ':(glob)**/generated/*')\""
  },
  "dependencies": {
    "@types/estree-jsx": "^1.0.5",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.3"
  },
  "devDependencies": {
    "@codspeed/vitest-plugin": "^5.4.0",
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@mdx-js/mdx": "^3.1.1",
    "@napi-rs/cli": "^3.7.2",
    "@napi-rs/wasm-runtime": "^1.1.5",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "fast-check": "^4.7.0",
    "hastscript": "^9.0.1",
    "knip": "^6.3.0",
    "mdast-util-mdx": "^3.0.0",
    "mdast-util-to-hast": "^13.2.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-directive": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "typescript": "^6.0.2",
    "unified": "^11.0.5",
    "vitest": "^4"
  },
  "napi": {
    "binaryName": "satteri_napi",
    "packageName": "@slikts/satteri",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "wasm32-wasip1-threads"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}

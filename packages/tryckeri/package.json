{
  "name": "tryckeri",
  "version": "0.1.13",
  "description": "High-performance Markdown processing",
  "files": [
    "dist",
    "browser.js",
    "index.js",
    "index.d.ts",
    "tryckeri_napi.wasi.cjs",
    "tryckeri_napi.wasi-browser.js",
    "wasi-worker.mjs",
    "wasi-worker-browser.js"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./arena-reader": "./dist/arena-reader.js"
  },
  "scripts": {
    "build:native": "napi build --manifest-path ../../crates/napi-binding/Cargo.toml --output-dir . --platform --release --esm",
    "build:native:debug": "napi build --manifest-path ../../crates/napi-binding/Cargo.toml --output-dir . --platform --esm",
    "build:ts": "tsc --project tsconfig.build.json",
    "build": "pnpm build:native && pnpm build:ts",
    "prepublishOnly": "napi prepublish --skip-gh-release",
    "artifacts": "napi create-npm-dirs && napi artifacts && napi version",
    "dev": "tsc --watch",
    "vitest": "vitest",
    "test": "vitest run",
    "bench": "vitest bench --run"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.5.0",
    "@types/unist": "^3.0.3",
    "mdast-util-mdx-expression": "^2.0.1",
    "mdast-util-mdx-jsx": "^3.2.0",
    "mdast-util-mdxjs-esm": "^2.0.1",
    "vitest": "^4"
  },
  "napi": {
    "binaryName": "tryckeri_napi",
    "packageName": "@bruits/tryckeri",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "wasm32-wasip1-threads"
    ]
  }
}

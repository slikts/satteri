{
  "name": "tryckeri",
  "version": "0.1.5",
  "description": "High-performance Markdown processing with Rust arena backend",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./arena-reader": "./dist/arena-reader.js"
  },
  "scripts": {
    "build:native": "napi build --manifest-path ../../crates/napi-binding/Cargo.toml --output-dir . --platform --release --esm",
    "build:native:debug": "napi build --manifest-path ../../crates/napi-binding/Cargo.toml --output-dir . --platform --esm",
    "build:ts": "tsc",
    "build": "pnpm build:native && pnpm build:ts",
    "dev": "tsc --watch",
    "vitest": "vitest",
    "test": "vitest run",
    "bench": "vitest bench --run"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^4"
  },
  "napi": {
    "binaryName": "tryckeri_napi",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "wasm32-wasip1-threads"
    ]
  }
}

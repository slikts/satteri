{
  "name": "vite-plugin-satteri",
  "version": "0.2.12",
  "description": "Vite plugin for processing Markdown and MDX with Sätteri",
  "keywords": [
    "markdown",
    "mdx",
    "satteri",
    "vite",
    "vite-plugin"
  ],
  "license": "MIT",
  "author": "Bruits",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bruits/satteri.git",
    "directory": "packages/vite-plugin-satteri"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm build:ts",
    "build:ts": "tsc --project tsconfig.build.json",
    "dev": "tsc --watch --project tsconfig.build.json",
    "test": "vitest run",
    "test-watch": "vitest"
  },
  "dependencies": {
    "smol-toml": "^1.6.1",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "satteri": "workspace:*",
    "vite": "^8",
    "vitest": "^4"
  },
  "peerDependencies": {
    "satteri": ">=0.4.0",
    "vite": "^5 || ^6 || ^7 || ^8"
  }
}

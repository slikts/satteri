{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "target",
    "dist",
    "crates/**/*",
    "!crates/*/README.md",
    "!crates/*/readme.md",
    "node_modules",
    "satteri_napi.*",
    "packages/satteri/index.d.ts",
    "packages/satteri/browser.js",
    "packages/satteri/index.js",
    "packages/satteri/browser.d.ts",
    "wasi-worker.mjs",
    "wasi-worker-browser.mjs"
  ],
  "overrides": [
    {
      "files": ["website/content/docs/**/*.md"],
      "options": { "proseWrap": "never", "printWidth": 200 }
    }
  ]
}
